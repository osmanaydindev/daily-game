# ─── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/dail-game

# JWT secrets — generate with: node -e "require('crypto').randomBytes(64).toString('hex')|console.log"
ACCESS_TOKEN_SECRET=replace_with_64_char_hex
REFRESH_TOKEN_SECRET=replace_with_64_char_hex

# Access token TTL (ms) — 15 minutes
ACCESS_TOKEN_TTL_MS=900000

# Refresh token TTL (ms) — 7 days
REFRESH_TOKEN_TTL_MS=604800000

# Admin seed values — used ONLY by the seed script
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe!1234
ADMIN_DISPLAY_NAME=Admin

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api
