{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@dail-game/types": ["../../packages/types/src/index.ts"]
    }
  },
  "include": ["src/**/*", "scripts/**/*", "../../packages/types/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
